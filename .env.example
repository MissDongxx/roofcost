# ============================================
# RoofCost AI - Environment Variables
# ============================================

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000" # 生产环境改为实际域名
NEXT_PUBLIC_APP_NAME="RoofCostAI"

# Theme & Appearance
NEXT_PUBLIC_THEME="default"
NEXT_PUBLIC_APPEARANCE="system" # system, light, dark

# Database - Supabase PostgreSQL
DATABASE_PROVIDER="postgresql"
DATABASE_URL="" # 从 Supabase Dashboard > Settings > Database 获取
DB_SCHEMA="roofcost"
DB_SINGLETON_ENABLED="true"
DB_MAX_CONNECTIONS="10" # Vercel Hobby 限制为 1，Pro 可用 10

# Authentication
# 生成命令: openssl rand -base64 32
AUTH_SECRET=""

# ============================================
# Payment Configuration
# ============================================
DEFAULT_PAYMENT_PROVIDER="paypal"

# PayPal
PAYPAL_ENABLED="true"
PAYPAL_ENVIRONMENT="sandbox" # sandbox or production
PAYPAL_CLIENT_ID="" # 从 PayPal Developer Dashboard 获取
PAYPAL_CLIENT_SECRET="" # 从 PayPal Developer Dashboard 获取
PAYPAL_WEBHOOK_ID="" # 从 PayPal Webhooks 获取

# Stripe (可选，用于未来扩展)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_REPORT="" # $39 one-time price ID

# ============================================
# AI Provider - Zhipu AI (智谱AI)
# ============================================
# API Key: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=""
ZHIPU_API_BASE="https://open.bigmodel.cn/api/paas/v4"

# ============================================
# Storage Configuration
# ============================================
# AWS S3 (可选，用于图片存储)
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"

# Supabase Storage (推荐，与数据库同源)
SUPABASE_STORAGE_URL=""
SUPABASE_STORAGE_ANON_KEY=""
SUPABASE_STORAGE_SERVICE_KEY=""